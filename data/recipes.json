  "ice_drip": {
    "name": {
      "zh": "冰滴",
      "en": "Ice Drip / Cold Drip"
    },
    "dose": "40-60g",
    "yield": {
      "zh": "400-600g冰水",
      "en": "400-600g ice water"
    },
    "temp": {
      "zh": "冰水混合",
      "en": "ice water"
    },
    "time": {
      "zh": "4-8小时(每秒1滴)",
      "en": "4-8h (1 drop/sec)"
    },
    "grind": {
      "zh": "中粗研磨",
      "en": "medium-coarse"
    },
    "gear": {
      "zh": "冰滴塔/壶+冰+滤纸/滤网",
      "en": "ice drip tower+ice+filter"
    },
    "steps": {
      "zh": "粉铺平→调阀门让冰水慢滴→接住咖啡→冷藏后喝",
      "en": "Level grounds→slow ice-water drip→collect→chill"
    },
    "adjust_bitter": {
      "zh": "粉磨粗/冰水多加水",
      "en": "coarser / more water"
    },
    "adjust_sour": {
      "zh": "阀门调慢/粉磨细",
      "en": "slower valve / finer"
    }
  },
  "clever_dripper": {
